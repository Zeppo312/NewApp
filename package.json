{
  "name": "lottibaby",
  "main": "expo-router/entry",
  "version": "1.0.18",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "start:localhost": "cross-env EXPO_PACKAGER_PROXY_URL=http://localhost:8081 expo start --localhost",
    "start:dev-client:localhost": "cross-env EXPO_PACKAGER_PROXY_URL=http://localhost:8081 expo start --dev-client --localhost",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "cross-env EXPO_PACKAGER_PROXY_URL=http://localhost:8081 LOTTI_IOS_JS_ENGINE=hermes node ./scripts/run-ios-dev.js",
    "ios:device": "cross-env EXPO_PACKAGER_PROXY_URL= REACT_NATIVE_PACKAGER_HOSTNAME= expo run:ios",
    "web": "expo start --web",
    "test": "jest --ci",
    "test:watch": "jest --watchAll",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "lint": "expo lint",
    "clean:update": "node ./scripts/prep-eas-update.js",
    "update": "node ./scripts/run-eas-update.js",
    "update:preview": "cross-env CI=1 node ./scripts/run-eas-update.js --channel preview --environment preview --platform ios",
    "update:production": "cross-env CI=1 node ./scripts/run-eas-update.js --channel production --environment production --platform ios",
    "update:dev": "cross-env CI=1 node ./scripts/run-eas-update.js --channel development --environment development --platform ios"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.7",
    "@craftzdog/react-native-buffer": "^6.0.5",
    "@expo/metro-runtime": "~57.0.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/slider": "5.2.0",
    "@react-native-picker/picker": "2.11.4",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.6.2",
    "@supabase/supabase-js": "^2.51.0",
