{
  "name": "lottibaby",
  "main": "expo-router/entry",
  "version": "1.0.6",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "start": "expo start",
    "start:localhost": "cross-env EXPO_PACKAGER_PROXY_URL=http://127.0.0.1:8081 expo start --localhost",
    "start:dev-client:localhost": "cross-env EXPO_PACKAGER_PROXY_URL=http://127.0.0.1:8081 expo start --dev-client --localhost",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "cross-env EXPO_PACKAGER_PROXY_URL=http://127.0.0.1:8081 expo run:ios",
    "ios:device": "cross-env EXPO_PACKAGER_PROXY_URL= REACT_NATIVE_PACKAGER_HOSTNAME= expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "clean:update": "node ./scripts/prep-eas-update.js",
    "update": "cross-env CI=1 node ./scripts/run-eas-update.js --auto",
    "update:dev": "node ./scripts/run-eas-update.js --branch main"
  },
  "jest": {
    "preset": "jest-expo"
  },
